# AI PRD Generator — Environment Variables

# ============================================================
# DATABASE
# ============================================================
# Development (PostgreSQL lokal)
DATABASE_URL="postgresql://postgres:password@localhost:5432/prd_generator"

# Production (Supabase) — uncomment saat deploy
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ============================================================
# BETTER AUTH
# ============================================================
BETTER_AUTH_SECRET="your-secret-min-32-chars-here-generate-with-openssl"
BETTER_AUTH_URL="http://localhost:3000"

# ============================================================
# GOOGLE OAUTH (opsional)
# ============================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================================
# AI PROVIDER
# Pilih salah satu: "9router" | "openai" | "anthropic" | "gemini"
# ============================================================
# AI PROVIDER - 9router (OpenAI-compatible combo model)
AI_PROVIDER="9router"

# 9router config
# Ganti dengan base URL dan API key dari akun 9router kamu
NINEROUTER_BASE_URL="http://localhost:20128/v1"
NINEROUTER_API_KEY=""
NINEROUTER_MODEL="combo1"   # Ganti dengan nama model combo dari 9router

# OpenAI (isi jika AI_PROVIDER=openai)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# Anthropic Claude (isi jika AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# Google Gemini (isi jika AI_PROVIDER=gemini)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-pro"
