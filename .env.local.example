# AI PRD Generator — Environment Variables

# ============================================================
# DATABASE
# ============================================================
# Development (PostgreSQL lokal)
DATABASE_URL="postgresql://postgres:password@localhost:5432/prd_generator"

# Production (Supabase) — uncomment saat deploy
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ============================================================
# BETTER AUTH
# ============================================================
BETTER_AUTH_SECRET="your-secret-min-32-chars-here-generate-with-openssl"
BETTER_AUTH_URL="http://localhost:3000"

# ============================================================
# GOOGLE OAUTH (opsional)
# ============================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================================
# AI PROVIDER
# Pilih salah satu: "mock" | "openai" | "anthropic" | "gemini"
# ============================================================
AI_PROVIDER="mock"

# OpenAI (isi jika AI_PROVIDER=openai)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# Anthropic Claude (isi jika AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# Google Gemini (isi jika AI_PROVIDER=gemini)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-pro"
